# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Firebase client config (Firebase Console > Project Settings > General > Your apps) ---
# These are public by design (enforced by firestore.rules, not secrecy) but should still live
# in env vars rather than source so they're easy to rotate/swap per environment.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin SDK (server-only) ---
# Firebase Console > Project Settings > Service Accounts > Generate new private key.
# Base64-encode the downloaded JSON file's contents and paste the result here, e.g.:
#   base64 -i service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=

# --- Razorpay ---
# Dashboard > Settings > API Keys. The key_id is safe to expose to the browser; key_secret must
# never leave the server.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- WhatsApp order alerts (CallMeBot) ---
# One-time setup: from the phone below, WhatsApp "I allow callmebot to send me messages" to
# +34 644 84 71 47, then set the API key it replies with.
CALLMEBOT_PHONE=919533866777
CALLMEBOT_APIKEY=

# --- Transactional email (Resend) ---
# Sign up free at resend.com, verify your sending domain, then create an API key.
RESEND_API_KEY=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.srigovindacollections.com

# --- Cloudinary (product photo uploads, server-only) ---
# Free tier, no card required: sign up at cloudinary.com, then copy the "API Environment
# variable" (CLOUDINARY_URL) shown on your Dashboard home page.
CLOUDINARY_URL=

# --- Shiprocket (order shipment creation + tracking, server-only) ---
# Create a dedicated API user: Shiprocket dashboard > Settings > API > Configure > Add New User.
# Grant Orders/Shipments/Courier module access; leave "Allowed IPs" blank (no fixed outbound IP
# on Vercel). Use that user's email/password here, not your main account login.
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# --- Cron authentication (server-only) ---
# Vercel Cron automatically sends this as a Bearer token when it triggers /api/cron/* routes.
# Generate any random string, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
