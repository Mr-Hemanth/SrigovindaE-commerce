rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the authenticated user is an admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // User profiles - only the owner can read/write their own profile
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId && request.resource.data.isAdmin == false;
      allow update: if request.auth != null && request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);
    }

    // Carts - only the owner can read/write their own cart
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Wishlists - only the owner can read/write their own wishlist
    match /wishlists/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Orders - created exclusively by the server (Admin SDK, which bypasses these rules) after
    // Razorpay signature verification / COD validation. Client-side creation is disabled so an
    // order can never be forged directly against Firestore.
    match /orders/{orderId} {
      allow create: if false;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      // Owners may update their own order (e.g. cancel, request return/exchange) but can never
      // touch financial/payment-identity fields, and can never set paymentStatus to 'Paid'
      // themselves (that only ever happens server-side after signature verification).
      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(
           ['userId', 'items', 'subtotal', 'discount', 'finalTotal', 'razorpayOrderId', 'razorpayPaymentId']
         ) &&
         (request.resource.data.paymentStatus == resource.data.paymentStatus ||
          request.resource.data.paymentStatus != 'Paid')) ||
        isAdmin()
      );
    }

    // Products - anyone can read, only admins can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coupons - anyone can read (needed for client-side pre-check before checkout; the
    // authoritative discount is recomputed server-side when the order is created), only admins can write
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reviews - public read, authenticated users can create their own review with a valid
    // rating; reviews are immutable once posted (no editing productId/userId/rating after the
    // fact) except by the author replacing text, and can be removed by their author or an admin.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.productId is string &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'productId']);
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // Site settings (e.g. the flash-sale promo banner) - publicly readable so the banner shows
    // to all visitors including guests, only admins can change it.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Restock notification requests - anyone (including guests) can submit a request to be
    // notified when a product is back in stock; only admins can view/manage the resulting list
    // since it contains customer contact details.
    match /notifications/{notificationId} {
      allow create: if request.resource.data.productId is string &&
        request.resource.data.contact is string;
      allow read, delete: if isAdmin();
    }

  }
}
